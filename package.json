{
  "name": "epicycle",
  "version": "0.1.0",
  "description": "Draw any shape and watch a Fourier series of spinning circles retrace it.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctkrug/epicycle.git"
  },
  "homepage": "https://github.com/ctkrug/epicycle#readme",
  "bugs": {
    "url": "https://github.com/ctkrug/epicycle/issues"
  },
  "scripts": {
    "test": "node --test test/",
    "test:coverage": "c8 --reporter=text --reporter=text-summary --check-coverage --lines 85 --branches 85 --functions 85 node --test test/",
    "lint": "eslint .",
    "dev": "npx --yes serve site"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "c8": "^10.1.3",
    "eslint": "^9.9.0",
    "fast-check": "^4.9.0"
